# ============================================================================
# CookHero 环境变量配置模板
# ============================================================================
# 使用说明：
# 1. 复制此文件为 .env：cp .env.example .env
# 2. 填写实际的 API Keys 和密码
# 3. 不要将 .env 文件提交到 Git（已在 .gitignore 中）
# ============================================================================

# ----------------------------------------------------------------------------
# LLM API 配置
# ----------------------------------------------------------------------------
# 主 LLM API Key（用于 normal 层级模型）
LLM_API_KEY=your_openai_or_custom_api_key_here

# 快速 LLM API Key（可选，用于 fast 层级模型，如意图识别、查询改写）
# 如果不设置，将使用 LLM_API_KEY
FAST_LLM_API_KEY=your_fast_model_api_key_here

# ----------------------------------------------------------------------------
# 数据库配置
# ----------------------------------------------------------------------------
# PostgreSQL 数据库密码
DATABASE_PASSWORD=your_postgres_password_here

# Redis 密码（可选，如果 Redis 未设置密码则留空）
REDIS_PASSWORD=

# Milvus 数据库用户名和密码
MILVUS_USER=root
MILVUS_PASSWORD=your_milvus_password_here

# ----------------------------------------------------------------------------
# Reranker 配置（可选）
# ----------------------------------------------------------------------------
# Reranker API Key（现在只支持 SiliconFlow Reranker）
# 如果不设置，将使用 LLM_API_KEY
RERANKER_API_KEY=your_reranker_api_key_here

# ----------------------------------------------------------------------------
# Web 搜索配置（可选）
# ----------------------------------------------------------------------------
# Tavily Web 搜索 API Key
# 获取地址：https://tavily.com/
WEB_SEARCH_API_KEY=your_tavily_api_key_here

# ----------------------------------------------------------------------------
# 身份认证配置
# ----------------------------------------------------------------------------
# JWT 密钥（用于生成和验证用户令牌）
# 建议使用随机生成的长字符串，可使用以下命令生成：
# python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=your_random_jwt_secret_key_here

# JWT 令牌过期时间（分钟）
JWT_EXPIRATION_MINUTES=1440
